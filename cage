#!/bin/bash
set -euo pipefail

CAGE_VERSION="0.8.2"
CAGE_REGISTRY="ghcr.io/sindycate/cage"

HOST_CLAUDE_DIR="$HOME/.claude"
CAGE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/cage"
AWS_CREDS="$HOME/.aws/credentials"
# Resolve symlinks to find the real script directory
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
BUILD_DIR="$SCRIPT_DIR"

# Top-level flags (before subcommand)
case "${1:-}" in
    --version|-V) echo "cage $CAGE_VERSION"; exit 0 ;;
    --help|-h)    set -- ;;  # clear args to trigger usage below
    setup|--setup)
        # Forward --profile to the setup wizard via env var
        if [ "${2:-}" = "--profile" ] && [ -n "${3:-}" ]; then
            export CAGE_SETUP_PROFILE="$3"
        fi
        source "$SCRIPT_DIR/cage-setup.sh"; exit $? ;;
    profiles|--profiles)
        shift
        source "$SCRIPT_DIR/cage-profiles.sh"; exit $? ;;
    netgate|--netgate)
        shift
        source "$SCRIPT_DIR/cage-netgate.sh"; exit $? ;;
esac

# Subcommand detection: cage [claude|codex] [options] /path/to/repo [tool-args...]
CAGE_TOOL=""
if [[ "${1:-}" == "claude" || "${1:-}" == "codex" ]]; then
    CAGE_TOOL="$1"
    shift
fi

YOLO=0
REBUILD=0
NET_MODE=""  # empty = not explicitly set
CAGE_PROFILE_FLAG=""

while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -y|--yolo)
            YOLO=1
            shift
            ;;
        --net)
            NET_MODE="${2:-gate}"
            shift 2
            ;;
        --net=*)
            NET_MODE="${1#--net=}"
            shift
            ;;
        --profile)
            CAGE_PROFILE_FLAG="${2:-}"
            [ -z "$CAGE_PROFILE_FLAG" ] && { echo "Missing profile name after --profile" >&2; exit 1; }
            [[ "$CAGE_PROFILE_FLAG" =~ ^[a-zA-Z0-9_-]+$ ]] || { echo "Invalid profile name: '$CAGE_PROFILE_FLAG' (use only letters, digits, hyphens, underscores)" >&2; exit 1; }
            shift 2
            ;;
        --profile=*)
            CAGE_PROFILE_FLAG="${1#--profile=}"
            [[ "$CAGE_PROFILE_FLAG" =~ ^[a-zA-Z0-9_-]+$ ]] || { echo "Invalid profile name: '$CAGE_PROFILE_FLAG' (use only letters, digits, hyphens, underscores)" >&2; exit 1; }
            shift
            ;;
        --rebuild)
            REBUILD=1
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# Default NET_MODE: gate when yolo, open otherwise
if [ -z "$NET_MODE" ]; then
    if [ "$YOLO" -eq 1 ]; then
        NET_MODE="gate"
    else
        NET_MODE="open"
    fi
fi

case "$NET_MODE" in
    open|gate|off) ;;
    *) echo "Invalid --net mode: $NET_MODE (use open, gate, or off)" >&2; exit 1 ;;
esac

if [ $# -lt 1 ]; then
    echo "Usage: cage [claude|codex] [-y|--yolo] [--rebuild] [--profile NAME] [--net open|gate|off] /path/to/repo [tool-args...]"
    echo ""
    echo "Tools:"
    echo "  claude    Run Claude Code (default)"
    echo "  codex     Run OpenAI Codex CLI"
    echo ""
    echo "Commands:"
    echo "  setup                     Run interactive configuration wizard"
    echo "  setup --profile NAME      Create/edit a named profile"
    echo "  profiles                  List profiles and folder mappings"
    echo "  profiles show NAME        Show a profile's configuration"
    echo "  profiles set PATH NAME    Assign a profile to a folder"
    echo "  profiles reset PATH       Remove a folder's profile mapping"
    echo "  netgate                    Manage domain allow/deny lists for --net gate"
    echo "  netgate list [PATH]        Show rules (defaults + global + project)"
    echo "  netgate allow DOMAIN       Allow a domain (project or --global)"
    echo "  netgate deny DOMAIN        Deny a domain (project)"
    echo "  netgate remove DOMAIN      Remove a decision (re-enables prompting)"
    echo "  netgate reset [PATH]       Delete all project decisions"
    echo ""
    echo "Options:"
    echo "  --profile NAME     Use a named config profile (one-shot override)"
    echo "  -y, --yolo         Skip all permission prompts"
    echo "  --net open         Full network access (default without --yolo)"
    echo "  --net gate         Domain-gated network via proxy (default with --yolo)"
    echo "  --net off          No network access at all"
    echo "  --rebuild          Force local rebuild (get latest tool version)"
    echo "  --version, -V      Show version and exit"
    echo "  --help, -h         Show this help and exit"
    echo ""
    echo "Examples:"
    echo "  cage setup"
    echo "  cage setup --profile work"
    echo "  cage ~/projects/myapp"
    echo "  cage --profile work ~/projects/myapp"
    echo "  cage codex ~/projects/myapp"
    echo "  cage codex -y ~/projects/myapp"
    echo "  cage -y ~/projects/myapp"
    echo "  cage --net gate ~/projects/myapp"
    echo "  cage ~/projects/myapp --resume"
    echo "  cage ~/projects/myapp -p 'explain this codebase'"
    exit 1
fi

REPO_PATH="$(cd "$1" && pwd -P)"
shift

# Guard: refuse to mount onto sensitive container paths. The repo is bind-mounted
# at its real host path inside the container, so these would collide with the
# container's own filesystem.
case "$REPO_PATH" in
    /|/etc|/etc/*|/usr|/usr/*|/var|/var/*|/bin|/bin/*|/sbin|/sbin/*|/lib|/lib/*|/lib64|/lib64/*|/proc|/proc/*|/sys|/sys/*|/dev|/dev/*|/root|/root/*|/home/claude|/home/claude/*|/home/codex|/home/codex/*|/workspace|/workspace/*)
        echo "ERROR: refusing to mount repo at '$REPO_PATH' — path conflicts with container filesystem" >&2
        exit 1
        ;;
esac

# Load config: global → profile → per-project override
PROFILES_DIR="$CAGE_CONFIG_DIR/profiles"
FOLDER_PROFILES_FILE="$CAGE_CONFIG_DIR/folder-profiles"

_init_config_vars() {
    GIT_USER_NAME="" GIT_USER_EMAIL="" SSH_KEY="" SSH_HOST="" CAGE_DEFAULT=""
    CLAUDE_AUTH="" AWS_PROFILE="" AWS_REGION="" EXTRA_ENV="" CODEX_COPY_AUTH="" GH_AUTH="" GH_ACCOUNT=""
    CAGE_PROFILE="" MCP_SERVERS="" SESSION_SYNC=""
}

_resolve_profile() {
    # Priority 1: CLI flag
    if [ -n "${CAGE_PROFILE_FLAG:-}" ]; then
        echo "$CAGE_PROFILE_FLAG"; return
    fi
    # Priority 2: CAGE_PROFILE in per-project .cage.conf (peek without full source)
    if [ -f "$REPO_PATH/.cage.conf" ]; then
        local proj_profile
        proj_profile="$(grep -m1 '^CAGE_PROFILE=' "$REPO_PATH/.cage.conf" 2>/dev/null | cut -d= -f2- | tr -d '"' | tr -d "'")" || true
        if [ -n "$proj_profile" ]; then
            echo "$proj_profile"; return
        fi
    fi
    # Priority 3: folder-profiles mapping
    if [ -f "$FOLDER_PROFILES_FILE" ]; then
        local mapped
        mapped="$(grep -m1 "^${REPO_PATH}=" "$FOLDER_PROFILES_FILE" 2>/dev/null | cut -d= -f2-)" || true
        if [ -n "$mapped" ]; then
            [ "$mapped" = "_none_" ] && return  # explicit "no profile"
            echo "$mapped"; return
        fi
    fi
    # Priority 4: interactive prompt (if 2+ profiles exist and TTY)
    if [ -t 0 ] && [ -d "$PROFILES_DIR" ]; then
        local profiles=()
        for f in "$PROFILES_DIR"/*.conf; do
            [ -f "$f" ] || continue
            profiles+=("$(basename "${f%.conf}")")
        done
        if [ ${#profiles[@]} -ge 2 ]; then
            # Use >&2 for display since stdout is captured by $()
            echo "" >&2
            echo "Multiple profiles available. Which one for $REPO_PATH?" >&2
            local i=1
            for p in "${profiles[@]}"; do
                echo "  ${i}) ${p}" >&2
                i=$((i + 1))
            done
            echo "  ${i}) (none — use global defaults only)" >&2
            local choice
            read -rp "  Choice [${i}]: " choice
            choice="${choice:-$i}"
            if [ "$choice" -ge 1 ] 2>/dev/null && [ "$choice" -lt "$i" ] 2>/dev/null; then
                local selected="${profiles[$((choice - 1))]}"
                mkdir -p "$CAGE_CONFIG_DIR"
                echo "${REPO_PATH}=${selected}" >> "$FOLDER_PROFILES_FILE"
                echo "$selected"; return
            else
                mkdir -p "$CAGE_CONFIG_DIR"
                echo "${REPO_PATH}=_none_" >> "$FOLDER_PROFILES_FILE"
                return
            fi
        fi
    fi
}

_load_config() {
    _init_config_vars
    # Step 1: global defaults
    [ -f "$CAGE_CONFIG_DIR/cage.conf" ] && source "$CAGE_CONFIG_DIR/cage.conf"
    # Step 2: resolve and load profile
    CAGE_PROFILE="$(_resolve_profile)" || true
    if [ -n "$CAGE_PROFILE" ]; then
        local profile_file="$PROFILES_DIR/${CAGE_PROFILE}.conf"
        if [ -f "$profile_file" ]; then
            source "$profile_file"
        else
            echo "Warning: profile '${CAGE_PROFILE}' not found at ${profile_file}" >&2
        fi
    fi
    # Step 3: per-project override (always wins)
    [ -f "$REPO_PATH/.cage.conf" ] && source "$REPO_PATH/.cage.conf" || true
}

# Auto-trigger setup wizard on first run (interactive terminal only)
if [ ! -f "$CAGE_CONFIG_DIR/cage.conf" ] && [ -t 0 ]; then
    echo "No configuration found. Running first-time setup..."
    echo ""
    source "$SCRIPT_DIR/cage-setup.sh"
fi

_load_config

# Resolve tool: explicit subcommand > CAGE_DEFAULT from config > "claude"
if [ -z "$CAGE_TOOL" ]; then
    CAGE_TOOL="${CAGE_DEFAULT:-claude}"
fi
case "$CAGE_TOOL" in
    claude|codex) ;;
    *) echo "Unknown tool: $CAGE_TOOL (use 'claude' or 'codex')" >&2; exit 1 ;;
esac

# Tool-specific variables
case "$CAGE_TOOL" in
    claude)
        IMAGE="claude-code:${CAGE_VERSION}"
        REGISTRY_IMAGE="${CAGE_REGISTRY}/claude-code:${CAGE_VERSION}"
        CONTAINER_PREFIX="claude"
        VOLUME_PREFIX="claude-state"
        CONTAINER_HOME="/home/claude"
        TOOL_DISPLAY_NAME="Claude Code"
        DOCKERFILE="Dockerfile"
        ;;
    codex)
        IMAGE="codex:${CAGE_VERSION}"
        REGISTRY_IMAGE="${CAGE_REGISTRY}/codex:${CAGE_VERSION}"
        CONTAINER_PREFIX="codex"
        VOLUME_PREFIX="codex-state"
        CONTAINER_HOME="/home/codex"
        TOOL_DISPLAY_NAME="Codex CLI"
        DOCKERFILE="Dockerfile.codex"
        ;;
esac

REPO_BASENAME="$(basename "$REPO_PATH")"
if command -v md5 &>/dev/null; then
    REPO_HASH="$(echo -n "$REPO_PATH" | md5 -q | cut -c1-8)"
else
    REPO_HASH="$(echo -n "$REPO_PATH" | md5sum | cut -c1-8)"
fi
CONTAINER_NAME="${CONTAINER_PREFIX}-${REPO_BASENAME}-${REPO_HASH}"
VOLUME_NAME="${VOLUME_PREFIX}-${REPO_BASENAME}-${REPO_HASH}"

# Image acquisition: pull from registry, fall back to local build
if [ "$REBUILD" -eq 1 ]; then
    echo "Rebuilding $IMAGE from local Dockerfile..."
    docker build --no-cache -t "$IMAGE" -t "${IMAGE%%:*}:latest" -f "$BUILD_DIR/$DOCKERFILE" "$BUILD_DIR"
elif ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Image $IMAGE not found locally."
    if docker pull "$REGISTRY_IMAGE" 2>/dev/null; then
        docker tag "$REGISTRY_IMAGE" "$IMAGE"
        docker tag "$REGISTRY_IMAGE" "${IMAGE%%:*}:latest"
        echo "Pulled $REGISTRY_IMAGE"
    else
        echo "Pull failed or unavailable. Building locally..."
        docker build -t "$IMAGE" -t "${IMAGE%%:*}:latest" -f "$BUILD_DIR/$DOCKERFILE" "$BUILD_DIR"
    fi
fi

YOLO_LABEL=""
if [ "$YOLO" -eq 1 ]; then
    YOLO_LABEL=" [YOLO]"
fi

NET_LABEL=""
case "$NET_MODE" in
    gate) NET_LABEL=" [NET:GATED]" ;;
    off)  NET_LABEL=" [NET:OFF]" ;;
esac

# --- Netgate proxy lifecycle ---

PROXY_PID=""

cleanup_proxy() {
    if [ -n "$PROXY_PID" ] && kill -0 "$PROXY_PID" 2>/dev/null; then
        kill "$PROXY_PID" 2>/dev/null
        # Give proxy up to 2s to exit, then force-kill
        for _ in 1 2 3 4; do
            kill -0 "$PROXY_PID" 2>/dev/null || break
            sleep 0.5
        done
        kill -9 "$PROXY_PID" 2>/dev/null || true
        wait "$PROXY_PID" 2>/dev/null || true
    fi
    rm -f "${PROXY_LOG:-}"
}

PROXY_ARGS=()

if [ "$NET_MODE" = "gate" ]; then
    PROXY_OUTPUT=$(mktemp)
    PROXY_LOG=$(mktemp)
    python3 "$SCRIPT_DIR/netgate-proxy.py" \
        --project-hash "$REPO_HASH" \
        --container-name "$CONTAINER_NAME" \
        > "$PROXY_OUTPUT" 2>"$PROXY_LOG" &
    PROXY_PID=$!

    # Wait for proxy to be ready (up to 3 seconds)
    for _ in $(seq 1 30); do
        if grep -q "^READY" "$PROXY_OUTPUT" 2>/dev/null; then break; fi
        # Check if proxy already exited
        if ! kill -0 "$PROXY_PID" 2>/dev/null; then break; fi
        sleep 0.1
    done

    if ! grep -q "^READY" "$PROXY_OUTPUT" 2>/dev/null; then
        echo "ERROR: netgate proxy failed to start" >&2
        cat "$PROXY_LOG" >&2
        cleanup_proxy
        rm -f "$PROXY_OUTPUT" "$PROXY_LOG"
        exit 1
    fi

    PROXY_PORT=$(grep "^PORT=" "$PROXY_OUTPUT" | head -1 | cut -d= -f2)
    rm -f "$PROXY_OUTPUT"

    PROXY_URL="http://host.docker.internal:${PROXY_PORT}"
    NET_LABEL=" [NET:GATED :${PROXY_PORT}]"

    PROXY_ARGS=(
        --add-host host.docker.internal:host-gateway
        -e "HTTP_PROXY=${PROXY_URL}"
        -e "HTTPS_PROXY=${PROXY_URL}"
        -e "http_proxy=${PROXY_URL}"
        -e "https_proxy=${PROXY_URL}"
        -e "NO_PROXY=localhost,127.0.0.1"
        -e "no_proxy=localhost,127.0.0.1"
    )

    trap cleanup_proxy EXIT
fi

if [ "$NET_MODE" = "off" ]; then
    PROXY_ARGS=(--network none)
fi

# --- MCP bridge lifecycle ---

MCP_BRIDGE_PID=""
MCP_BRIDGE_ARGS=()
MCP_LABEL=""
MCP_JSON_BACKUP=""

cleanup_mcp_bridge() {
    # Restore .mcp.json if we patched it
    if [ -n "$MCP_JSON_BACKUP" ] && [ -f "$MCP_JSON_BACKUP" ]; then
        cp "$MCP_JSON_BACKUP" "$REPO_PATH/.mcp.json"
        rm -f "$MCP_JSON_BACKUP"
    fi
    if [ -n "$MCP_BRIDGE_PID" ] && kill -0 "$MCP_BRIDGE_PID" 2>/dev/null; then
        kill "$MCP_BRIDGE_PID" 2>/dev/null
        for _ in 1 2 3 4; do
            kill -0 "$MCP_BRIDGE_PID" 2>/dev/null || break
            sleep 0.5
        done
        kill -9 "$MCP_BRIDGE_PID" 2>/dev/null || true
        wait "$MCP_BRIDGE_PID" 2>/dev/null || true
    fi
    rm -f "${MCP_BRIDGE_LOG:-}"
}

if [ -n "${MCP_SERVERS:-}" ]; then
    if [ "$NET_MODE" = "off" ]; then
        echo "WARNING: MCP_SERVERS ignored — network is disabled (--net off)" >&2
    else
        BRIDGE_ARGS=()
        while IFS= read -r line; do
            line="$(echo "$line" | xargs)"
            [ -z "$line" ] && continue
            srv_name="${line%%=*}"
            srv_cmd="${line#*=}"
            BRIDGE_ARGS+=(--server "$srv_name" "$srv_cmd")
        done <<< "${MCP_SERVERS}"

        if [ ${#BRIDGE_ARGS[@]} -gt 0 ]; then
            MCP_BRIDGE_OUTPUT=$(mktemp)
            MCP_BRIDGE_LOG=$(mktemp)
            python3 "$SCRIPT_DIR/mcp-bridge.py" "${BRIDGE_ARGS[@]}" \
                > "$MCP_BRIDGE_OUTPUT" 2>"$MCP_BRIDGE_LOG" &
            MCP_BRIDGE_PID=$!

            for _ in $(seq 1 30); do
                if grep -q "^READY" "$MCP_BRIDGE_OUTPUT" 2>/dev/null; then break; fi
                if ! kill -0 "$MCP_BRIDGE_PID" 2>/dev/null; then break; fi
                sleep 0.1
            done

            if ! grep -q "^READY" "$MCP_BRIDGE_OUTPUT" 2>/dev/null; then
                echo "ERROR: MCP bridge failed to start" >&2
                cat "$MCP_BRIDGE_LOG" >&2
                cleanup_mcp_bridge
                rm -f "$MCP_BRIDGE_OUTPUT" "$MCP_BRIDGE_LOG"
                exit 1
            fi

            # Build JSON map and env vars for container
            CAGE_MCP_JSON="{"
            _first=1
            while IFS= read -r sline; do
                srv_name=$(echo "$sline" | sed 's/^SERVER:\(.*\)=PORT:.*/\1/')
                srv_port=$(echo "$sline" | sed 's/.*=PORT://')
                upper_name=$(echo "$srv_name" | tr '[:lower:]-' '[:upper:]_')
                MCP_BRIDGE_ARGS+=(-e "MCP_BRIDGE_PORT_${upper_name}=${srv_port}")
                [ "$_first" -eq 1 ] && _first=0 || CAGE_MCP_JSON+=","
                CAGE_MCP_JSON+="\"${srv_name}\":${srv_port}"
            done < <(grep "^SERVER:" "$MCP_BRIDGE_OUTPUT")
            CAGE_MCP_JSON+="}"

            MCP_BRIDGE_ARGS+=(
                -e "MCP_BRIDGE_HOST=host.docker.internal"
                -e "CAGE_MCP_SERVERS=${CAGE_MCP_JSON}"
            )

            # Add host.docker.internal if netgate hasn't already
            if [ "$NET_MODE" != "gate" ]; then
                MCP_BRIDGE_ARGS+=(--add-host host.docker.internal:host-gateway)
            fi

            # Patch .mcp.json in the repo if it defines any bridged servers
            if [ -f "$REPO_PATH/.mcp.json" ]; then
                MCP_JSON_BACKUP=$(mktemp)
                cp "$REPO_PATH/.mcp.json" "$MCP_JSON_BACKUP"
                python3 -c "
import json, sys
with open('$REPO_PATH/.mcp.json') as f:
    cfg = json.load(f)
bridged = set(sys.argv[1:])
changed = False
for name in list(cfg.get('mcpServers', {})):
    if name in bridged:
        cfg['mcpServers'][name] = {'type': 'stdio', 'command': 'mcp-relay', 'args': [name]}
        changed = True
if changed:
    with open('$REPO_PATH/.mcp.json', 'w') as f:
        json.dump(cfg, f, indent=4)
" $(grep "^SERVER:" "$MCP_BRIDGE_OUTPUT" | sed 's/^SERVER:\(.*\)=PORT:.*/\1/') 2>/dev/null || true
            fi

            rm -f "$MCP_BRIDGE_OUTPUT"

            MCP_LABEL=" [MCP]"

            trap 'cleanup_mcp_bridge; cleanup_proxy' EXIT
        fi
    fi
fi

# --- Session history sync (Claude only) -------------------------------------
# Two-part flow, always run for Claude (migration is unconditional since the
# mount path moved; host-sync is gated by SESSION_SYNC):
#
#   1. Legacy-session migration (in-volume only) — rewrites sessions that were
#      recorded under the old /workspace/<name>/ cwd so they resume under the
#      new host-path cwd. Always runs to avoid stranding history on upgrade.
#   2. Host<->volume sync — bidirectional copy of the single project's JSONL
#      files between ~/.claude/projects/-<slug>/ and the per-repo Docker
#      volume. All host-side writes happen here, in the host cage script
#      running as the host user. The container's read-only /host-claude mount
#      is unchanged.
SESSION_SLUG=""
if [ "$CAGE_TOOL" = "claude" ]; then
    SESSION_SLUG="$(echo -n "$REPO_PATH" | tr '/' '-')"
    HOST_PROJ_DIR="$HOST_CLAUDE_DIR/projects/$SESSION_SLUG"
    SESSION_SYNC_ENABLED="${SESSION_SYNC:-1}"

    docker volume create "$VOLUME_NAME" >/dev/null

    # -v for the host dir is added only when the dir exists, to avoid docker
    # auto-creating it as root on the host.
    SYNC_IN_MOUNTS=(-v "$VOLUME_NAME:/vol")
    if [ "$SESSION_SYNC_ENABLED" = "1" ] && [ -d "$HOST_PROJ_DIR" ]; then
        SYNC_IN_MOUNTS+=(-v "$HOST_PROJ_DIR:/src:ro")
    fi
    docker run --rm \
        "${SYNC_IN_MOUNTS[@]}" \
        -e "SLUG=$SESSION_SLUG" \
        -e "REPO_PATH=$REPO_PATH" \
        -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" \
        alpine:3 sh -c '
            DST="/vol/projects/$SLUG"
            mkdir -p "$DST"

            # Merge one file into $DST. Rules:
            #   *.jsonl → size-based (append-only: larger wins; equal size syncs mtime
            #             from src, which also repairs mtimes stamped "now" by v0.8.0).
            #   other   → mtime-based (newer wins). Memory .md, .meta.json, tool-results.
            sync_one() {
                src="$1"; dst="$2"; rel="$3"
                mkdir -p "$(dirname "$dst")"
                if [ ! -e "$dst" ]; then
                    cp -p "$src" "$dst"
                    return
                fi
                case "$rel" in
                    *.jsonl)
                        ss=$(stat -c%s "$src"); ds=$(stat -c%s "$dst")
                        if [ "$ss" -gt "$ds" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        elif [ "$ss" = "$ds" ]; then
                            touch -r "$src" "$dst"
                        fi
                        ;;
                    *)
                        sm=$(stat -c%Y "$src"); dm=$(stat -c%Y "$dst")
                        if [ "$sm" -gt "$dm" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        fi
                        ;;
                esac
            }

            # 1) Host → volume (whole subtree).
            if [ -d /src ]; then
                cd /src && find . -type f | while read rel; do
                    rel="${rel#./}"
                    sync_one "/src/$rel" "$DST/$rel" "$rel"
                done
            fi

            # 2) Legacy slug → new slug. Runs after host sync so legacy mtimes are
            #    authoritative for legacy-only files (and repairs stamped-now mtimes).
            #    For .jsonl: rewrite embedded "cwd":"/workspace/..." so Claude --resume matches.
            for old in /vol/projects/-workspace-*; do
                [ -d "$old" ] || continue
                cd "$old" && find . -type f | while read rel; do
                    rel="${rel#./}"
                    src="$old/$rel"; dst="$DST/$rel"
                    mkdir -p "$(dirname "$dst")"
                    case "$rel" in
                        *.jsonl)
                            if [ ! -e "$dst" ]; then
                                sed "s|\"cwd\":\"/workspace/[^\"]*\"|\"cwd\":\"$REPO_PATH\"|g" "$src" > "$dst.tmp" \
                                    && mv "$dst.tmp" "$dst" \
                                    && touch -r "$src" "$dst"
                            else
                                # Already migrated — legacy mtime is authoritative.
                                touch -r "$src" "$dst"
                            fi
                            ;;
                        *)
                            if [ ! -e "$dst" ]; then
                                cp -p "$src" "$dst"
                            else
                                sm=$(stat -c%Y "$src"); dm=$(stat -c%Y "$dst")
                                if [ "$sm" -gt "$dm" ]; then
                                    cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                                fi
                            fi
                            ;;
                    esac
                done
            done

            chown -R "$HOST_UID:$HOST_GID" "$DST"
        ' >/dev/null 2>&1 || true

    # If host-sync is disabled, don't register sync-out cleanup.
    [ "$SESSION_SYNC_ENABLED" = "1" ] || SESSION_SLUG=""
fi

cleanup_session_sync() {
    [ -z "$SESSION_SLUG" ] && return 0
    mkdir -p "$HOST_CLAUDE_DIR/projects/$SESSION_SLUG"
    # Sync-out: copy volume JSONLs back to host, size-guarded (append-only JSONL → larger = newer).
    # Runs as host UID:GID so files land with correct ownership.
    docker run --rm \
        --user "$(id -u):$(id -g)" \
        -v "$VOLUME_NAME:/vol:ro" \
        -v "$HOST_CLAUDE_DIR/projects/$SESSION_SLUG:/dst" \
        -e "SLUG=$SESSION_SLUG" \
        alpine:3 sh -c '
            SRC="/vol/projects/$SLUG"
            [ -d "$SRC" ] || exit 0
            cd "$SRC" && find . -type f | while read rel; do
                rel="${rel#./}"
                src="$SRC/$rel"; dst="/dst/$rel"
                mkdir -p "$(dirname "$dst")"
                if [ ! -e "$dst" ]; then
                    cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                    continue
                fi
                case "$rel" in
                    *.jsonl)
                        ss=$(stat -c%s "$src"); ds=$(stat -c%s "$dst")
                        if [ "$ss" -gt "$ds" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        elif [ "$ss" = "$ds" ]; then
                            # Content matches: propagate corrected mtime from volume to host.
                            touch -r "$src" "$dst"
                        fi
                        ;;
                    *)
                        sm=$(stat -c%Y "$src"); dm=$(stat -c%Y "$dst")
                        if [ "$sm" -gt "$dm" ]; then
                            cp -p "$src" "$dst.tmp" && mv "$dst.tmp" "$dst"
                        fi
                        ;;
                esac
            done
        ' >/dev/null 2>&1 || true
}

echo "=== ${TOOL_DISPLAY_NAME} Container${YOLO_LABEL}${NET_LABEL}${MCP_LABEL} ==="
echo "  Repo:      $REPO_PATH"
[ -n "$CAGE_PROFILE" ] && echo "  Profile:   $CAGE_PROFILE"
echo "  Container: $CONTAINER_NAME"
echo "  Volume:    $VOLUME_NAME"
echo "=============================="

# Shared Docker args
DOCKER_ARGS=(
    --rm
    -it
    --name "$CONTAINER_NAME"
    --hostname "$CONTAINER_NAME"
    --cap-drop ALL
    --cap-add CHOWN
    --cap-add DAC_OVERRIDE
    --cap-add SETGID
    --cap-add SETUID
    --tmpfs /tmp
    --tmpfs /run
    -v "$REPO_PATH:$REPO_PATH"
    -e "WORKSPACE_DIR=$REPO_PATH"
    -e "HOST_UID=$(id -u)"
    -e "HOST_GID=$(id -g)"
)

# Tool-specific Docker args
case "$CAGE_TOOL" in
    claude)
        DOCKER_ARGS+=(
            --security-opt apparmor=unconfined
            --security-opt seccomp=unconfined
            -v "$VOLUME_NAME:${CONTAINER_HOME}/.claude"
            -v "$HOST_CLAUDE_DIR:/host-claude:ro"
        )
        # Auth: bedrock (default) or api-key
        case "${CLAUDE_AUTH:-bedrock}" in
            bedrock)
                DOCKER_ARGS+=(
                    -e "CLAUDE_CODE_USE_BEDROCK=1"
                    -e "AWS_PROFILE=${AWS_PROFILE:-}"
                    -e "AWS_REGION=${AWS_REGION:-}"
                    -v "$AWS_CREDS:${CONTAINER_HOME}/.aws/credentials:ro"
                )
                ;;
            api-key)
                if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
                    echo "ERROR: CLAUDE_AUTH=api-key but ANTHROPIC_API_KEY is not set" >&2
                    exit 1
                fi
                DOCKER_ARGS+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
                ;;
            *)
                echo "Invalid CLAUDE_AUTH: $CLAUDE_AUTH (use 'bedrock' or 'api-key')" >&2
                exit 1
                ;;
        esac
        ;;
    codex)
        DOCKER_ARGS+=(
            # Codex CLI uses bubblewrap to sandbox tool calls (apply_patch, rg, etc).
            # bwrap needs user namespaces, which Docker's seccomp/AppArmor block by default.
            # The container itself is the security boundary, so this is safe to relax.
            --security-opt apparmor=unconfined
            --security-opt seccomp=unconfined
            -v "$VOLUME_NAME:${CONTAINER_HOME}/.codex"
        )
        if [ -d "$HOME/.codex" ]; then
            DOCKER_ARGS+=(-v "$HOME/.codex:/host-codex:ro")
        fi
        if [ -n "${OPENAI_API_KEY:-}" ]; then
            DOCKER_ARGS+=(-e "OPENAI_API_KEY=$OPENAI_API_KEY")
        fi
        if [ "${CODEX_COPY_AUTH:-1}" = "0" ]; then
            DOCKER_ARGS+=(-e "CODEX_COPY_AUTH=0")
        fi
        ;;
esac

# Git/SSH mounts and env vars (from cage.conf)
if [ -n "$GIT_USER_NAME" ]; then
    DOCKER_ARGS+=(-e "GIT_USER_NAME=$GIT_USER_NAME")
fi
if [ -n "$GIT_USER_EMAIL" ]; then
    DOCKER_ARGS+=(-e "GIT_USER_EMAIL=$GIT_USER_EMAIL")
fi
if [ -n "$SSH_KEY" ]; then
    SSH_KEY_PATH="${SSH_KEY/#\~/$HOME}"
    if [ -f "$SSH_KEY_PATH" ]; then
        DOCKER_ARGS+=(-v "$SSH_KEY_PATH:${CONTAINER_HOME}/.ssh/id:ro")
        DOCKER_ARGS+=(-e 'GIT_SSH_COMMAND=ssh -i '"${CONTAINER_HOME}"'/.ssh/id -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new')
        [ -f "$HOME/.ssh/known_hosts" ] && DOCKER_ARGS+=(-v "$HOME/.ssh/known_hosts:${CONTAINER_HOME}/.ssh/known_hosts:ro")
    fi
fi
if [ -n "$SSH_HOST" ]; then
    DOCKER_ARGS+=(-e "SSH_HOST=$SSH_HOST")
fi

# Extra env vars from cage.conf
for varname in $EXTRA_ENV; do
    if [ -n "${!varname:-}" ]; then
        DOCKER_ARGS+=(-e "$varname=${!varname}")
    fi
done

# GitHub CLI auth (opt-in via GH_AUTH=1 in cage.conf)
if [ "${GH_AUTH:-0}" = "1" ]; then
    HOST_GH_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/gh"
    if [ -d "$HOST_GH_DIR" ]; then
        DOCKER_ARGS+=(-v "$HOST_GH_DIR:/host-gh:ro")
    fi

    # Auto-extract token from host gh if no explicit token
    if [ -z "${GH_TOKEN:-}" ] && [ -z "${GITHUB_TOKEN:-}" ]; then
        if command -v gh &>/dev/null; then
            if [ -n "${GH_ACCOUNT:-}" ]; then
                GH_TOKEN="$(gh auth token -u "$GH_ACCOUNT" 2>/dev/null)" || true
            else
                GH_TOKEN="$(gh auth token 2>/dev/null)" || true
            fi
        fi
    fi

    if [ -n "${GH_TOKEN:-}" ]; then
        DOCKER_ARGS+=(-e "GH_TOKEN=$GH_TOKEN")
    elif [ -n "${GITHUB_TOKEN:-}" ]; then
        DOCKER_ARGS+=(-e "GH_TOKEN=$GITHUB_TOKEN")
    fi
fi

[[ ${#PROXY_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${PROXY_ARGS[@]}")
[[ ${#MCP_BRIDGE_ARGS[@]} -gt 0 ]] && DOCKER_ARGS+=("${MCP_BRIDGE_ARGS[@]}")

TOOL_ARGS=()
if [ "$YOLO" -eq 1 ]; then
    case "$CAGE_TOOL" in
        claude) TOOL_ARGS+=(--dangerously-skip-permissions) ;;
        codex)  TOOL_ARGS+=(--yolo)
                DOCKER_ARGS+=(-e "CAGE_YOLO=1") ;;
    esac
fi

if [ "$NET_MODE" = "gate" ] || [ -n "$MCP_BRIDGE_PID" ] || [ -n "$SESSION_SLUG" ]; then
    # Cannot use exec: need cleanup traps to run via trap EXIT
    trap 'cleanup_session_sync; cleanup_mcp_bridge; cleanup_proxy' EXIT
    docker run "${DOCKER_ARGS[@]}" "$IMAGE" ${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"} "$@"
else
    exec docker run "${DOCKER_ARGS[@]}" "$IMAGE" ${TOOL_ARGS[@]+"${TOOL_ARGS[@]}"} "$@"
fi
