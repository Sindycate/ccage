FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    bash \
    bubblewrap \
    ca-certificates \
    curl \
    git \
    jq \
    less \
    procps \
    ripgrep \
 && rm -rf /var/lib/apt/lists/*

# Install Node.js LTS (needed for Codex CLI npm package)
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install Codex CLI globally (as root, before user switch)
RUN npm install -g @openai/codex

RUN useradd -m -s /bin/bash codex && \
    mkdir -p /home/codex/.local/bin /home/codex/.codex /home/codex/.ssh && \
    chmod 700 /home/codex/.ssh && \
    chown -R codex:codex /home/codex

COPY entrypoint-codex.sh /home/codex/entrypoint.sh
RUN chown codex:codex /home/codex/entrypoint.sh && chmod 755 /home/codex/entrypoint.sh

USER codex
ENV HOME=/home/codex
ENV PATH=/home/codex/.local/bin:$PATH
ENV HISTFILE=/dev/null

WORKDIR /home/codex
ENTRYPOINT ["/home/codex/entrypoint.sh"]
